# ── Адрес сайта (канонический, без слэша в конце) ──
NEXT_PUBLIC_SITE_URL=https://verh.tech

# ── Контакты (показываются на сайте; меняются здесь + rebuild, без правки кода) ──
NEXT_PUBLIC_CONTACT_EMAIL=hi@verh.tech
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/verh_studio
NEXT_PUBLIC_TELEGRAM_HANDLE=@verh_studio

# ── Бот приёма заявок (@verhstudio_bot) ──
# 1) Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# 2) Кому слать уведомления о заявках: ID через запятую (узнать свой — команда /id в боте)
TELEGRAM_ADMIN_IDS=
# 3) Секрет вебхука (любая случайная строка; тот же секрет передать в setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# ── Верификация поисковых панелей (коды из Яндекс.Вебмастера / Search Console) ──
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ── Яндекс.Метрика (числовой id счётчика из metrika.yandex.ru; пусто — счётчик не подключается) ──
NEXT_PUBLIC_YM_ID=
